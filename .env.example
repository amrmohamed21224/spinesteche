# -----------------------------------------------------------------------------
# SpinesTech — Frontend environment (Vite)
# -----------------------------------------------------------------------------

# WordPress Headless API base (no trailing slash on path segments after v1)
# Example: https://cms.yourdomain.com/wp-json/spinestech/v1
VITE_API_URL=https://YOUR-WP-DOMAIN.com/wp-json/spinestech/v1

# Set to false when WordPress plugin is live and populated
VITE_USE_MOCKS=true

# Public site URL (SEO, canonical)
VITE_SITE_URL=https://spinestech.sa

# Google Analytics
VITE_GA_ID=G-XXXXXXXXXX
